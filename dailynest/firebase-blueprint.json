/**
 * Defines the structure of the FirebaseBlueprint configuration.
 */
{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A productivity task created by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string", "maxLength": 150 },
        "description": { "type": "string", "maxLength": 2000 },
        "status": { "type": "string", "enum": ["todo", "in_progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "status", "priority", "createdAt", "updatedAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A daily or weekly habit tracked by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string", "maxLength": 100 },
        "frequency": { "type": "string", "enum": ["daily", "weekly"] },
        "color": { "type": "string", "maxLength": 20 },
        "icon": { "type": "string", "maxLength": 50 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "frequency", "createdAt", "updatedAt"]
    },
    "HabitLog": {
      "title": "Habit Log",
      "description": "A specific instance of completing a habit on a given date.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "habitId": { "type": "string" },
        "date": { "type": "string" }, 
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "habitId", "date", "completedAt"]
    },
    "Journal": {
      "title": "Journal",
      "description": "A daily journal entry created by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string", "maxLength": 200 },
        "content": { "type": "string", "maxLength": 100000 },
        "mood": { "type": "string", "maxLength": 20 },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "mood", "date", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "User tasks"
    },
    "/habits/{habitId}": {
      "schema": { "$ref": "#/entities/Habit" },
      "description": "User habits to track"
    },
    "/habit_logs/{logId}": {
      "schema": { "$ref": "#/entities/HabitLog" },
      "description": "Completion records for habits"
    },
    "/journals/{journalId}": {
      "schema": { "$ref": "#/entities/Journal" },
      "description": "User journals"
    }
  }
}
